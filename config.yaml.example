vaults:
  - name: Personal
    vault_path: /Users/yourname/Documents/Obsidian/Personal
    vault_name: Personal
    tasks_folder: "24 Tasks"
    claude_script: claude-obsidian-personal.sh
  - name: Brogrammers
    vault_path: /Users/yourname/Documents/Obsidian/Brogrammers
    vault_name: Brogrammers
    tasks_folder: "40 Tasks"
    claude_script: claude-obsidian-brogrammers.sh

# Optional overrides (these are the defaults)
#claude_cli: claude
#host: 127.0.0.1
#port: 8000
